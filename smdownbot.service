[Unit]
Description=Social Media Downloader Telegram Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/hermes/smdownbot
EnvironmentFile=/opt/hermes/smdownbot/.env
ExecStart=/opt/hermes/smdownbot/.venv/bin/python bot.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
